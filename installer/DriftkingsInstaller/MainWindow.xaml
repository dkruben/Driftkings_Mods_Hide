<Window x:Class="DriftkingsInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Driftkings Mods Installer"
        Width="1180"
        Height="820"
        MinWidth="1040"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#09131A"
        Icon="Assets/icon.png">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#4DE3B5" />
        <SolidColorBrush x:Key="TextBrush" Color="#EAF7F7" />
        <SolidColorBrush x:Key="MutedBrush" Color="#8DAAB2" />

        <Style x:Key="PillToggleStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#20333D" />
            <Setter Property="BorderBrush" Value="#36515F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#183F39" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#042326" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#74F0CA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#081118" Offset="0" />
                <GradientStop Color="#0D1D28" Offset="0.45" />
                <GradientStop Color="#14252B" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="1.35*" />
        </Grid.ColumnDefinitions>

        <Border Margin="26" CornerRadius="28" Background="#0E1A22" BorderBrush="#213543" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="300" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Margin="22" CornerRadius="22" ClipToBounds="True">
                    <Grid>
                        <Image Source="Assets/hero.png" Stretch="Fill" />
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#080F14" Offset="0" />
                                    <GradientStop Color="#00233644" Offset="0.55" />
                                    <GradientStop Color="#CC081118" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <StackPanel VerticalAlignment="Bottom" Margin="26">
                            <TextBlock Text="DRIFTKINGS" Foreground="#CFFBF4" FontSize="14" FontWeight="Bold" />
                            <TextBlock Text="Modern Installer" Foreground="White" FontSize="36" FontWeight="Bold" />
                            <TextBlock Text="Instala o modpack diretamente na raiz do World of Tanks para as regioes EU e NA."
                                       Foreground="#B4D2D7"
                                       Margin="0,10,0,0"
                                       FontSize="15"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="26,0,26,26">
                    <Border Background="#13222B" BorderBrush="#20333D" BorderThickness="1" CornerRadius="22" Padding="22">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="Assets/icon.png" Width="56" Height="56" />
                                <StackPanel Margin="14,0,0,0">
                                    <TextBlock x:Name="TitleText" Text="Driftkings Mods" Foreground="White" FontSize="24" FontWeight="Bold" />
                                    <TextBlock x:Name="SubtitleText" Text="Payload pronto para EU e NA" Foreground="{StaticResource MutedBrush}" FontSize="14" />
                                </StackPanel>
                            </StackPanel>

                            <UniformGrid Margin="0,20,0,0" Columns="2">
                                <Border Background="#0D171D" CornerRadius="16" Padding="16" Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="Versao do jogo" Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock x:Name="GameVersionText" Text="-" Foreground="White" FontSize="22" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#0D171D" CornerRadius="16" Padding="16" Margin="10,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="Pacotes disponiveis" Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock x:Name="PackageCountText" Text="-" Foreground="White" FontSize="22" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{StaticResource MutedBrush}"
                                       Text="Escolha os pacotes de mods e a opcao de limpeza de cache na mesma lista de selecao." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Margin="0,26,26,26" CornerRadius="28" Background="#0F1B24" BorderBrush="#213543" BorderThickness="1">
            <Grid Margin="26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Destino e Regiao" Foreground="White" FontSize="28" FontWeight="Bold" />
                    <TextBlock Margin="0,8,0,0" Text="Escolha a regiao, valide a versao do jogo e selecione os itens que quer executar." Foreground="{StaticResource MutedBrush}" />

                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                        <ToggleButton x:Name="EuRegionButton" Style="{StaticResource PillToggleStyle}" Content="EU" Checked="RegionButton_Checked" />
                        <ToggleButton x:Name="NaRegionButton" Style="{StaticResource PillToggleStyle}" Content="NA" Checked="RegionButton_Checked" />
                    </StackPanel>

                    <TextBlock Margin="0,18,0,8" Text="Instalacoes detetadas" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="DetectedInstallationsComboBox"
                                  Height="46"
                                  Padding="10,6"
                                  Background="#13222B"
                                  BorderBrush="#28424F"
                                  BorderThickness="1"
                                  Foreground="White"
                                  DisplayMemberPath="DisplayLabel"
                                  SelectionChanged="DetectedInstallationsComboBox_SelectionChanged" />
                        <Button Grid.Column="1"
                                Margin="12,0,0,0"
                                Width="118"
                                Height="46"
                                Click="RefreshDetectionsButton_Click"
                                Style="{StaticResource ActionButtonStyle}"
                                Content="Detetar" />
                    </Grid>

                    <TextBlock Margin="0,18,0,8" Text="Pasta raiz do World of Tanks" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="InstallPathTextBox"
                                 Height="48"
                                 Padding="14,10"
                                 Background="#13222B"
                                 BorderBrush="#28424F"
                                 BorderThickness="1"
                                 Foreground="White"
                                 FontSize="14"
                                 TextChanged="InstallPathTextBox_TextChanged" />
                        <Button Grid.Column="1"
                                Margin="12,0,0,0"
                                Width="118"
                                Height="48"
                                Click="BrowseButton_Click"
                                Style="{StaticResource ActionButtonStyle}"
                                Content="Procurar" />
                    </Grid>

                    <TextBlock x:Name="VersionStatusTextBlock"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               Text="A validar versao do cliente..." />
                </StackPanel>

                <Border Grid.Row="1" Margin="0,24,0,0" Padding="18" Background="#13222B" CornerRadius="22" BorderBrush="#20333D" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Selecao de instalacao" Foreground="White" FontSize="20" FontWeight="Bold" />
                            <TextBlock x:Name="SelectionSummaryText" Margin="0,6,0,0" Foreground="{StaticResource MutedBrush}" Text="-" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Width="118" Height="40" Margin="0,0,10,0" Click="SelectAllButton_Click" Style="{StaticResource ActionButtonStyle}" Content="Tudo" />
                            <Button Width="118" Height="40" Click="ClearSelectionButton_Click" Background="#20333D" Foreground="White" BorderBrush="#36515F" BorderThickness="1" Content="Limpar" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Margin="0,16,0,0" Background="#0D171D" CornerRadius="22" BorderBrush="#1D313C" BorderThickness="1" Padding="10">
                    <ListBox x:Name="PackagesListBox"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10" Padding="14" Background="#12212A" CornerRadius="18" BorderBrush="#213643" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                            <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="SemiBold" FontSize="15" />
                                            <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource MutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding SizeLabel}" VerticalAlignment="Center" Foreground="#B7F5E8" FontWeight="SemiBold" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <StackPanel Grid.Row="3" Margin="0,22,0,0">
                    <TextBlock x:Name="StatusTextBlock" Foreground="{StaticResource MutedBrush}" Text="Pronto para instalar." />
                    <ProgressBar x:Name="InstallProgressBar" Height="14" Margin="0,10,0,0" Minimum="0" Maximum="100" />
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="FooterTextBlock"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="Destino: raiz do jogo. Regioes suportadas: EU e NA." />
                        <Button x:Name="InstallButton"
                                Grid.Column="1"
                                Width="188"
                                Height="52"
                                Click="InstallButton_Click"
                                Style="{StaticResource ActionButtonStyle}"
                                Content="Aplicar Selecao" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
